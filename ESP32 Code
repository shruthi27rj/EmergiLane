#include <BLEDevice.h>
#include <BLEUtils.h>
#include <BLEScan.h>

#define SCAN_TIME 2

BLEScan* pBLEScan;

// 🚦 Pins (use these EXACT ones you tested)
int redA = 13;
int greenA = 12;

int redB = 27;
int greenB = 26;

// 🚑 Detection
int rssiA = -1000;
int rssiB = -1000;
bool ambA = false;
bool ambB = false;

// 📡 BLE Callback
class MyCallbacks: public BLEAdvertisedDeviceCallbacks {
  void onResult(BLEAdvertisedDevice device) {

    if (device.haveName()) {
      String name = device.getName().c_str();

      Serial.print("Detected: ");
      Serial.print(name);
      Serial.print(" | RSSI: ");
      Serial.println(device.getRSSI());

      if (name == "AMB1") {
        ambA = true;
        rssiA = device.getRSSI();
      }

      if (name == "AMB2") {
        ambB = true;
        rssiB = device.getRSSI();
      }
    }
  }
};

// 🚦 Default traffic state
void normalTraffic() {

  Serial.println("Normal Traffic");

  // Road A green
  digitalWrite(greenA, HIGH);
  digitalWrite(redA, LOW);

  digitalWrite(redB, HIGH);
  digitalWrite(greenB, LOW);

  delay(3000);

  // Switch
  digitalWrite(greenA, LOW);
  digitalWrite(redA, HIGH);

  digitalWrite(redB, LOW);
  digitalWrite(greenB, HIGH);

  delay(3000);
}

// 🚑 Priority A
void priorityA() {

  Serial.println("🚑 Priority: Road A");

  digitalWrite(greenA, HIGH);
  digitalWrite(redA, LOW);

  digitalWrite(redB, HIGH);
  digitalWrite(greenB, LOW);

  delay(3000);
}

// 🚑 Priority B
void priorityB() {

  Serial.println("🚑 Priority: Road B");

  digitalWrite(greenB, HIGH);
  digitalWrite(redB, LOW);

  digitalWrite(redA, HIGH);
  digitalWrite(greenA, LOW);

  delay(3000);
}

void setup() {
  Serial.begin(115200);

  pinMode(redA, OUTPUT);
  pinMode(greenA, OUTPUT);
  pinMode(redB, OUTPUT);
  pinMode(greenB, OUTPUT);

  // Default ON so you SEE something instantly
  digitalWrite(redA, HIGH);
  digitalWrite(redB, HIGH);

  // BLE setup
  BLEDevice::init("");
  pBLEScan = BLEDevice::getScan();
  pBLEScan->setAdvertisedDeviceCallbacks(new MyCallbacks());
  pBLEScan->setActiveScan(true);

  Serial.println("System Ready 🚦");
}

void loop() {

  // Reset detection
  ambA = false;
  ambB = false;
  rssiA = -1000;
  rssiB = -1000;

  Serial.println("Scanning...");

  // Scan BLE
  pBLEScan->start(SCAN_TIME, false);
  pBLEScan->clearResults();

  // 🧠 Decision logic
  if (ambA && !ambB) {
    priorityA();
  }
  else if (ambB && !ambA) {
    priorityB();
  }
  else if (ambA && ambB) {

    Serial.println("Both ambulances detected");

    if (rssiA > rssiB) {
      priorityA();
      delay(1000);
      priorityB();
    } else {
      priorityB();
      delay(1000);
      priorityA();
    }
  }
  else {
    normalTraffic();
  }
}
